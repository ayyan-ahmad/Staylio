<% layout("layouts/boilerplate") %>
<!-- <script>
const mapToken ="<%= process.env.MAP_tOKEN %>";
</script> -->
<div class="row">
  <div class="col-8 offset-3">
    <h3><%= listing.title %></h3>

    <!-- CARD: ONLY IMAGE -->
    <div class="card col-6 border-0">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top show-img"
        alt="listing_image"
      />
    </div>

    <!-- CONTENT OUTSIDE IMAGE BORDER -->
    <div class="card-body">
      <p class="card-text">
        <b>Owned by:</b> <%= listing.owner.username %>
        </p>
      <p class="card-text"><b>Description:</b> <%= listing.description %></p>
      <p class="card-text"><b>Price:</b> ₹ <%= listing.price.toLocaleString("en-IN") %></p>
      <p class="card-text"><b>Location:</b> <%= listing.location %></p>
      <p class="card-text"><b>Country:</b> <%= listing.country %></p>

      <!-- Buttons -->
      <% if(currentUser && listing.owner._id.equals(currentUser._id)) { %>
      <div class="d-flex gap-2 mt-2">
        <a href="/listings/<%= listing._id %>/edit" class="btn edt-btn">
          Edit
        </a>

        <form
          method="post"
          action="/listings/<%= listing._id %>?_method=DELETE"
        >
          <button class="btn btn-dark">Delete</button>
        </form>
      </div>
      <% } %>
      
    </div>

<% if(currentUser) { %>
    <!-- Review Form -->
    <hr />
    <h4>Leave a Review</h4>

    <form action="/listings/<%= listing._id %>/reviews" method="POST">
      
       <div class="mb-3 mt-3">
           <label class="form-label">Rating (1–5)</label>
<fieldset class="starability-slot ">


  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div>
      <div class="mb-3">
        <label class="form-label">Comment</label>
        <textarea
          name="review[comment]"
          rows="4"
          class="form-control"
          required
        ></textarea>
      </div>

      <button class="btn btn-primary">Submit Review</button>
    </form>
<%} %>
    <!-- Reviews -->
    <hr />
  <% if(listing.reviews.length>0) { %>
    <div class="row">
        <p><b> All Reviews</b></p>

   
      <% for(let review of listing.reviews) { %>
        <div class="card col-5  ms-3 mb-3">
            <div class="card-body">
                <h5 class="card-title">@<%= review.author.username %> </h5>
                <p
                  class="starability-result card-text" data-rating="<%= review.rating %>">
                </p>
                <p class="card-text"><%= review.comment %></p>
                
                </div>
                <form class="mb-3" method="post"
  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
  <button class="btn btn-dark">Delete</button>
</form>

            </div>
      <% } %>
        </div>  
        <% }  %>
  </div>
  <!-- <div  class="col-6 offset-3 mb-3" >
          <h3> Where you'll be staying</h3>
          <div id="map" ></div>

        </div> -->
</div>
<!-- 
<script src="/js/map.js"> -->
  
</script>